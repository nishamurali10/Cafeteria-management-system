<main>
  <header class="relative pt-16 isolate">
    <div class="absolute inset-0 overflow-hidden -z-10" aria-hidden="true">
      <div class="absolute -mt-16 opacity-50 left-16 top-full transform-gpu blur-3xl xl:left-1/2 xl:-ml-80">
        <div class="aspect-[1154/678] w-[72.125rem] bg-gradient-to-br from-[#FF80B5] to-[#9089FC]" style="clip-path: polygon(100% 38.5%, 82.6% 100%, 60.2% 37.7%, 52.4% 32.1%, 47.5% 41.8%, 45.2% 65.6%, 27.5% 23.4%, 0.1% 35.3%, 17.9% 0%, 27.7% 23.4%, 76.2% 2.5%, 74.2% 56%, 100% 38.5%)"></div>
      </div>
      <div class="absolute inset-x-0 bottom-0 h-px bg-gray-900/5"></div>
    </div>
    <div class="px-4 py-10 mx-auto max-w-7xl sm:px-6 lg:px-8">
      <div class="flex items-center justify-between max-w-2xl mx-auto gap-x-8 lg:mx-0 lg:max-w-none">
        <div class="flex items-center gap-x-6">
          <h1>
            <div class="text-sm leading-6 text-gray-500">Order <span class="text-gray-700">#<%= @order.id %></span></div>
            <div class="mt-1 text-base font-semibold leading-6 text-gray-900"><%= @order.customer.name %></div>
          </h1>
        </div>
        <div class="flex items-center gap-x-4 sm:gap-x-6">
          <%= link_to "Edit", edit_order_path(@order), class: "block text-sm font-semibold leading-6 text-gray-900" %>
        </div>
      </div>
    </div>
  </header>
  <div class="px-4 py-16 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="grid items-start max-w-2xl grid-cols-1 grid-rows-1 mx-auto gap-x-8 gap-y-8 lg:mx-0 lg:max-w-none lg:grid-cols-3">
      <!-- Invoice summary -->
      <div class="lg:col-start-3 lg:row-end-1">
        <h2 class="sr-only">Summary</h2>
        <div class="rounded-lg shadow-sm bg-gray-50 ring-1 ring-gray-900/5">
          <dl class="flex flex-wrap">
            <div class="flex-auto pt-6 pl-6">
              <dt class="text-sm font-semibold leading-6 text-gray-900">Amount</dt>
              <dd class="mt-1 text-base font-semibold leading-6 text-gray-900"><%= number_to_currency(@order.total, unit: "₹") %></dd>
            </div>
            <div class="self-end flex-none px-6 pt-4">
              <dt class="sr-only">Status</dt>
              <dd class="px-2 py-1 text-xs font-medium text-green-600 rounded-md bg-green-50 ring-1 ring-inset ring-green-600/20">Paid</dd>
            </div>
            <div class="flex flex-none w-full px-6 pt-6 mt-6 border-t gap-x-4 border-gray-900/5">
              <dt class="flex-none">
                <span class="sr-only">Client</span>
                <svg class="w-5 h-6 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-slot="icon">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-5.5-2.5a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0ZM10 12a5.99 5.99 0 0 0-4.793 2.39A6.483 6.483 0 0 0 10 16.5a6.483 6.483 0 0 0 4.793-2.11A5.99 5.99 0 0 0 10 12Z" clip-rule="evenodd" />
                </svg>
              </dt>
              <dd class="text-sm font-medium leading-6 text-gray-900"><%= @order.customer.name %></dd>
            </div>
            <div class="flex flex-none w-full px-6 mt-4 gap-x-4">
              <dt class="flex-none">
                <span class="sr-only">Due date</span>
                <svg class="w-5 h-6 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-slot="icon">
                  <path d="M5.25 12a.75.75 0 0 1 .75-.75h.01a.75.75 0 0 1 .75.75v.01a.75.75 0 0 1-.75.75H6a.75.75 0 0 1-.75-.75V12ZM6 13.25a.75.75 0 0 0-.75.75v.01c0 .414.336.75.75.75h.01a.75.75 0 0 0 .75-.75V14a.75.75 0 0 0-.75-.75H6ZM7.25 12a.75.75 0 0 1 .75-.75h.01a.75.75 0 0 1 .75.75v.01a.75.75 0 0 1-.75.75H8a.75.75 0 0 1-.75-.75V12ZM8 13.25a.75.75 0 0 0-.75.75v.01c0 .414.336.75.75.75h.01a.75.75 0 0 0 .75-.75V14a.75.75 0 0 0-.75-.75H8ZM9.25 10a.75.75 0 0 1 .75-.75h.01a.75.75 0 0 1 .75.75v.01a.75.75 0 0 1-.75.75H10a.75.75 0 0 1-.75-.75V10ZM10 11.25a.75.75 0 0 0-.75.75v.01c0 .414.336.75.75.75h.01a.75.75 0 0 0 .75-.75V12a.75.75 0 0 0-.75-.75H10ZM9.25 14a.75.75 0 0 1 .75-.75h.01a.75.75 0 0 1 .75.75v.01a.75.75 0 0 1-.75.75H10a.75.75 0 0 1-.75-.75V14ZM12 9.25a.75.75 0 0 0-.75.75v.01c0 .414.336.75.75.75h.01a.75.75 0 0 0 .75-.75V10a.75.75 0 0 0-.75-.75H12ZM11.25 12a.75.75 0 0 1 .75-.75h.01a.75.75 0 0 1 .75.75v.01a.75.75 0 0 1-.75.75H12a.75.75 0 0 1-.75-.75V12ZM12 13.25a.75.75 0 0 0-.75.75v.01c0 .414.336.75.75.75h.01a.75.75 0 0 0 .75-.75V14a.75.75 0 0 0-.75-.75H12ZM13.25 10a.75.75 0 0 1 .75-.75h.01a.75.75 0 0 1 .75.75v.01a.75.75 0 0 1-.75.75H14a.75.75 0 0 1-.75-.75V10ZM14 11.25a.75.75 0 0 0-.75.75v.01c0 .414.336.75.75.75h.01a.75.75 0 0 0 .75-.75V12a.75.75 0 0 0-.75-.75H14Z" />
                  <path fill-rule="evenodd" d="M5.75 2a.75.75 0 0 1 .75.75V4h7V2.75a.75.75 0 0 1 1.5 0V4h.25A2.75 2.75 0 0 1 18 6.75v8.5A2.75 2.75 0 0 1 15.25 18H4.75A2.75 2.75 0 0 1 2 15.25v-8.5A2.75 2.75 0 0 1 4.75 4H5V2.75A.75.75 0 0 1 5.75 2Zm-1 5.5c-.69 0-1.25.56-1.25 1.25v6.5c0 .69.56 1.25 1.25 1.25h10.5c.69 0 1.25-.56 1.25-1.25v-6.5c0-.69-.56-1.25-1.25-1.25H4.75Z" clip-rule="evenodd" />
                </svg>
              </dt>
              <dd class="text-sm leading-6 text-gray-500">
                <time datetime="2023-01-31"><%= @order.created_at.strftime('%e %b %Y') %></time>
              </dd>
            </div>
            <div class="flex flex-none w-full px-6 mt-4 gap-x-4">
              <dt class="flex-none">
                <span class="sr-only">Status</span>
                <svg class="w-5 h-6 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" data-slot="icon">
                  <path fill-rule="evenodd" d="M2.5 4A1.5 1.5 0 0 0 1 5.5V6h18v-.5A1.5 1.5 0 0 0 17.5 4h-15ZM19 8.5H1v6A1.5 1.5 0 0 0 2.5 16h15a1.5 1.5 0 0 0 1.5-1.5v-6ZM3 13.25a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 0 1.5h-1.5a.75.75 0 0 1-.75-.75Zm4.75-.75a.75.75 0 0 0 0 1.5h3.5a.75.75 0 0 0 0-1.5h-3.5Z" clip-rule="evenodd" />
                </svg>
              </dt>
              <dd class="text-sm leading-6 text-gray-500">Paid by <%= @order.payment_terms %></dd>
            </div>
          </dl>
          <div class="px-6 py-6 mt-6 border-t border-gray-900/5">
            <%= link_to order_show_pdf_path(@order, format: :pdf), target: :_blank, class: "text-sm font-semibold leading-6 text-gray-900" do %>
              Download receipt <span aria-hidden="true">&rarr;</span>
            <% end %>
          </div>
        </div>
      </div>
      <!-- Invoice -->
      <div class="px-4 py-8 -mx-4 shadow-sm ring-1 ring-gray-900/5 sm:mx-0 sm:rounded-lg sm:px-8 sm:pb-14 lg:col-span-2 lg:row-span-2 lg:row-end-2 xl:px-16 xl:pb-20 xl:pt-16">
        <h2 class="text-base font-semibold leading-6 text-gray-900">Order #<%= @order.id %></h2>
        <dl class="grid grid-cols-1 mt-6 text-sm leading-6">
          <div class="sm:pr-4">
            <dt class="inline text-gray-500">Customer:</dt>
            <dd class="inline text-gray-700"><span><%= @order.customer.name %></span></dd>
          </div>
          <div class="sm:pr-4">
            <dt class="inline text-gray-500">Issued on:</dt>
            <dd class="inline text-gray-700"><time datetime="<%= @order.created_at %>"><%= @order.created_at.strftime('%e %b %Y') %></time></dd>
          </div>
          <div class="pt-6 mt-6 border-t border-gray-900/5 sm:pr-4">
            <dt class="font-semibold text-gray-900">Thanks for Ordering at</dt>
            <dd class="mt-2 text-gray-500"><span class="font-medium text-gray-900">Cafe, Inc.</span><br>
              7363 Cynthia Pass<br>
              Toronto, ON N3Y 4H8</dd>
          </div>
        </dl>
        <table class="w-full mt-16 text-sm leading-6 text-left whitespace-nowrap">
          <colgroup>
            <col class="w-full">
            <col>
            <col>
            <col>
          </colgroup>
          <thead class="text-gray-900 border-b border-gray-200">
            <tr>
              <th scope="col" class="px-0 py-3 font-semibold">Items</th>
              <th scope="col" class="hidden py-3 pl-8 pr-0 font-semibold text-right sm:table-cell">Quantity</th>
              <th scope="col" class="hidden py-3 pl-8 pr-0 font-semibold text-right sm:table-cell">Price</th>
              <th scope="col" class="py-3 pl-8 pr-0 font-semibold text-right">Amount</th>
            </tr>
          </thead>
          <tbody>
            <%= render partial: "order_items/show_items", collection: @order.order_items, as: :item %>
          </tbody>
          <tfoot>
            <tr>
              <th scope="row" class="pt-4 font-semibold text-gray-900 sm:hidden">Total</th>
              <th scope="row" colspan="3" class="hidden pt-4 font-semibold text-right text-gray-900 sm:table-cell">Total</th>
              <td class="pt-4 pb-0 pl-8 pr-0 font-semibold text-right text-gray-900 tabular-nums"><%= number_to_currency(@order.total, unit: "₹") %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>
</main>