<%= form_with(model: order) do |form| %>
  <%= render "error_messages", resource: form.object %>
  <%= turbo_frame_tag "order_frame", data: {controller: "order"} do %>
    <div class="space-y-12">
      <div class="grid grid-cols-1 mt-10 gap-x-6 gap-y-8 sm:grid-cols-6">
        <div class="sm:col-span-4">
          <%= form.label :customer_id, class: "block text-sm font-medium leading-6 text-gray-900" %>
          <div class="mt-2">
            <div class="flex rounded-md shadow-sm ring-1 ring-inset ring-gray-300 focus-within:ring-2 focus-within:ring-inset focus-within:ring-indigo-600 sm:max-w-md">
              <%= form.select :customer_id, Customer.all.collect { |p| [ p.name, p.id ] }, { prompt: "Select a customer" }, class: "block flex-1 border-0 bg-transparent py-1.5 pl-1 text-gray-900 placeholder:text-gray-400 focus:ring-0 sm:text-sm sm:leading-6" %>
            </div>
          </div>
        </div>
        <div class="sm:col-span-4">
          <%= form.label :payment_terms, class: "block text-sm font-medium leading-6 text-gray-900" %>
          <div class="mt-2">
            <div class="flex rounded-md shadow-sm ring-1 ring-inset ring-gray-300 focus-within:ring-2 focus-within:ring-inset focus-within:ring-indigo-600 sm:max-w-md">
              <%= form.select :payment_terms, Order.payment_terms.keys, {prompt: "Select the payment mode"}, class: "block flex-1 border-0 bg-transparent py-1.5 pl-1 text-gray-900 placeholder:text-gray-400 focus:ring-0 sm:text-sm sm:leading-6" %>
            </div>
          </div>
        </div>
        <div class="sm:col-span-4">
          <div class="mt-5" data-controller="nested-form">
            <div class="bg-white border border-gray-200 rounded-sm " >
              <!-- Table -->
              <div class="overflow-x-auto">
                <table class="w-full table-auto">
                  <!-- Table header -->
                  <thead class="text-xs font-semibold text-gray-500 uppercase border-t border-b border-gray-200 bg-gray-50">
                    <tr>
                      <th class="w-3/6 px-2 py-3 first:pl-5 last:pr-5 whitespace-nowrap">
                        <div class="font-semibold text-left">Item Details</div>
                      </th>
                      <th class="w-0 px-2 py-3 first:pl-5 last:pr-5 whitespace-nowrap">
                        <div class="font-semibold text-left">Quantity</div>
                      </th>
                      <th class="w-1/6 px-2 py-3 first:pl-5 last:pr-5 whitespace-nowrap">
                        <div class="font-semibold text-left">Price</div>
                      </th>
                      <th class="w-1/6 px-2 py-3 first:pl-5 last:pr-5 whitespace-nowrap">
                        <div class="font-semibold text-right">Amount</div>
                      </th>
                      <th class="px-2 py-3 first:pl-5 last:pr-5 whitespace-nowrap">
                        <div class="font-semibold text-left">
                          <span class="sr-only">Actions</span>
                        </div>
                      </th>
                    </tr>
                  </thead>
                  <!-- Table body -->
                  <tbody class="text-sm divide-y divide-gray-200">
                    <!-- Row -->
                    <template data-nested-form-target="template">
                      <%= form.fields_for :order_items, OrderItem.new, child_index: 'NEW_RECORD' do |builder| %>
                        <%= render partial: "order_items/form", locals: {f: builder}%>
                      <% end %>
                    </template>
                    <%= form.fields_for :order_items do |builder| %>
                      <%= render partial: "order_items/form", locals: {f: builder}%>
                    <% end %>
                    <tr class="hidden" data-nested-form-target="form"></tr>
                  </tbody>
                </table>
              </div>
            </div>
            <div class="mt-5" data-nested-form-target="links">
              <a class="inline-flex items-center gap-x-1.5 rounded-md bg-indigo-600 px-2.5 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 cursor-pointer" data-action= "click->nested-form#add_association">
                <svg class="w-3 h-3 opacity-50 fill-current shrink-0" viewBox="0 0 16 16">
                  <path d="M15 7H9V1c0-.6-.4-1-1-1S7 .4 7 1v6H1c-.6 0-1 .4-1 1s.4 1 1 1h6v6c0 .6.4 1 1 1s1-.4 1-1V9h6c.6 0 1-.4 1-1s-.4-1-1-1z" />
                </svg>
                <span class="ml-2">Add another line</span>
              </a>
            </div>
            <div class="w-full py-2 mt-5 ml-auto mr-16 sm:w-2/4 lg:w-1/4 ">
              <%# Total Sales %>
              <div class="flex justify-between mb-3">
                <div class="w-full font-semibold text-left text-md text-grey-800">
                  Total
                </div>
                <div class="text-right w-36">
                  <div data-order-target="saleTotal" class="font-semibold text-gray-800 text-md" >0.00</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="flex items-center mt-6 gap-x-6">
      <%= form.submit class: "px-3 py-2 text-sm font-semibold text-white bg-indigo-600 rounded-md shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 cursor-pointer" %>
    </div>
  <% end %>
<% end %>