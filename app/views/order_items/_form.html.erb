<tr class="nested-fields" data-new-record=<%= f.object.new_record? %>>
  <%= f.hidden_field :_destroy %>
  <td class="w-4/6 px-2 py-3 first:pl-5 last:pr-5 whitespace-nowrap">
    <div class="flex rounded-md shadow-sm ring-1 ring-inset ring-gray-300 focus-within:ring-2 focus-within:ring-inset focus-within:ring-indigo-600 sm:max-w-md">
      <%= f.select :food_id, Food.all.map {|p| [p.name,p.id]}, {prompt: "Select a Food"}, {class: "w-full block flex-1 border-0 bg-transparent py-1.5 pl-1 text-gray-900 placeholder:text-gray-400 focus:ring-0 sm:text-sm sm:leading-6", data: {action: "change->order#select", order_target: "food"}} %>
    </div>
  </td>
  <td class="w-0 px-2 py-3 first:pl-5 last:pr-5 whitespace-nowrap">
    <div class="flex rounded-md shadow-sm ring-1 ring-inset ring-gray-300 focus-within:ring-2 focus-within:ring-inset focus-within:ring-indigo-600 sm:max-w-md">
      <%= f.number_field :qty, step: 1, class:"w-full block flex-1 border-0 bg-transparent py-1.5 pl-1 text-gray-900 placeholder:text-gray-400 focus:ring-0 sm:text-sm sm:leading-6 text-center", data: {action: "change->order#update", order_target: "qty"} %>
    </div>
  </td>
  <td class="w-1/6 px-2 py-3 first:pl-5 last:pr-5 whitespace-nowrap">
    <div class="flex rounded-md shadow-sm ring-1 ring-inset ring-gray-300 focus-within:ring-2 focus-within:ring-inset focus-within:ring-indigo-600 sm:max-w-md">
      <%= f.number_field :price, step: 0.01, class:"w-full block flex-1 border-0 bg-transparent py-1.5 pl-1 text-gray-900 placeholder:text-gray-400 focus:ring-0 sm:text-sm sm:leading-6 text-right", data: {action: "change->order#update", order_target: "price"}  %>
    </div>
  </td>
  <td class="w-0 px-2 py-3 text-right first:pl-5 last:pr-5 whitespace-nowrap">
    <div class="font-semibold text-gray-800" data-order-target="amount"></div>
  </td>
  <td class="w-px px-2 py-3 first:pl-5 last:pr-5 whitespace-nowrap">
    <div class="space-x-1">
      <a class="block float-right text-red-500 bg-red-100 rounded-full hover:text-red-600" data-action="click->nested-form#remove_association">
        <span class="sr-only">Delete</span>
        <svg class="w-6 h-6 fill-current" viewBox="0 0 32 32">
          <path class="db" d="M15.95 14.536l4.242-4.243a1 1 0 111.415 1.414l-4.243 4.243 4.243 4.242a1 1 0 11-1.415 1.415l-4.242-4.243-4.243 4.243a1 1 0 01-1.414-1.415l4.243-4.242-4.243-4.243a1 1 0 011.414-1.414l4.243 4.243z"></path>
        </svg>
      </a>
    </div>
  </td>
</tr>