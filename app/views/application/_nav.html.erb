<nav class="bg-white border-b border-gray-200 print:hidden">
  <div class="px-4 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <div class="flex">
        <div class="flex items-center flex-shrink-0">
          <%= link_to "Cafe App", authenticated_root_path %>
        </div>
        <div class="hidden sm:-my-px sm:ml-6 sm:flex sm:space-x-8">
          <!-- Current: "border-indigo-500 text-gray-900", Default: "border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700" -->
          <a href="/customers" class="inline-flex items-center px-1 pt-1 text-sm font-medium" aria-current="page">Customers</a>
          <a href="/orders" class="inline-flex items-center px-1 pt-1 text-sm font-medium text-gray-500 hover:text-gray-700">Orders</a>
          <a href="/orders/new" class="inline-flex items-center px-1 pt-1 text-sm font-medium text-gray-500 hover:text-gray-700">Manage Orders</a>
        </div>
      </div>
      <div class="hidden sm:ml-6 sm:flex sm:items-center">
        <!-- Profile dropdown -->
        <% if user_signed_in? %>
          <div class="relative ml-3" data-controller="dropdown">
            <div
            data-action="click@window->dropdown#hide touchstart@window->dropdown#hide keydown.up->dropdown#previousItem keydown.down->dropdown#nextItem keydown.esc->dropdown#hide">
              <button type="button" class="relative flex items-center max-w-xs text-sm bg-white rounded-full focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" id="user-menu-button" aria-expanded="false" aria-haspopup="true"
            data-action="dropdown#toggle:stop"
            >
                <span class="absolute -inset-1.5"></span>
                <span class="sr-only">Open user menu</span>
                <span class="inline-flex items-center justify-center w-8 h-8 bg-gray-500 rounded-full">
                  <span class="text-sm font-medium leading-none text-white uppercase"><%= current_user.email[0,2]%></span>
                </span>
              </button>
            </div>
            <div class="absolute right-0 z-10 hidden w-48 py-1 mt-2 origin-top-right bg-white rounded-md shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none" role="menu" aria-orientation="vertical" aria-labelledby="user-menu-button" tabindex="-1"
          data-dropdown-target="menu">
              <!-- Active: "bg-gray-100", Not Active: "" -->
              <%= link_to "Profile", edit_user_registration_path, class: "block px-4 py-2 text-sm text-gray-700",role:"menuitem", tabindex:"-1" %>
              <% if user_signed_in? && current_user.is_admin? %>
                <%= link_to "Admin", avo_path, class: "block px-4 py-2 text-sm text-gray-700",role:"menuitem", tabindex:"-1" %>
              <% end %>
              <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "block px-4 py-2 text-sm text-gray-700", role:"menuitem", tabindex:"-1" %>
            </div>
          </div>
        <% end %>
      </div>
      <div class="flex items-center -mr-2 sm:hidden">
        <!-- Mobile menu button -->
        <button type="button" class="relative inline-flex items-center justify-center p-2 text-gray-400 bg-white rounded-md hover:bg-gray-100 hover:text-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" aria-controls="mobile-menu" aria-expanded="false">
          <span class="absolute -inset-0.5"></span>
          <span class="sr-only">Open main menu</span>
          <!-- Menu open: "hidden", Menu closed: "block" -->
          <svg class="block w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" data-slot="icon">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <!-- Menu open: "block", Menu closed: "hidden" -->
          <svg class="hidden w-6 h-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" data-slot="icon">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>
  <!-- Mobile menu, show/hide based on menu state. -->
  <div class="sm:hidden" id="mobile-menu">
    <div class="pt-2 pb-3 space-y-1">
      <!-- Current: "border-indigo-500 bg-indigo-50 text-indigo-700", Default: "border-transparent text-gray-600 hover:border-gray-300 hover:bg-gray-50 hover:text-gray-800" -->
      <a href="/customers" class="block py-2 pl-3 pr-4 text-base font-medium text-gray-600 border-l-4 border-transparent hover:border-gray-300 hover:bg-gray-50 hover:text-gray-800">Customers</a>
      <a href="/orders" class="block py-2 pl-3 pr-4 text-base font-medium text-gray-600 border-l-4 border-transparent hover:border-gray-300 hover:bg-gray-50 hover:text-gray-800">Orders</a>
      <a href="/orders/new" class="block py-2 pl-3 pr-4 text-base font-medium text-gray-600 border-l-4 border-transparent hover:border-gray-300 hover:bg-gray-50 hover:text-gray-800">Manage Orders</a>
    </div>
    <% if user_signed_in? %>
      <div class="pt-4 pb-3 border-t border-gray-200">
        <div class="flex items-center px-4">
          <div class="flex-shrink-0">
            <span class="inline-flex items-center justify-center w-8 h-8 bg-gray-500 rounded-full">
              <span class="text-sm font-medium leading-none text-white uppercase"><%= current_user.email[0,2]%></span>
            </span>
          </div>
        </div>
        <div class="mt-3 space-y-1">
          <%= link_to "Profile", edit_user_registration_path, class: "block px-4 py-2 text-base font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-800" %>
          <% if current_user.is_admin? %>
            <%= link_to "Admin", avo_path, class: "block px-4 py-2 text-base font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-800" %>
          <% end %>
          <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "block px-4 py-2 text-base font-medium text-gray-500 hover:bg-gray-100 hover:text-gray-800" %>
        </div>
      </div>
    <% end %>
  </div>
</nav>
