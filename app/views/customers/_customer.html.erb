<tr>
  <td class="py-4 pl-4 pr-3 text-sm font-medium text-gray-900 whitespace-nowrap sm:pl-0"><%= customer.name %></td>
  <td class="px-3 py-4 text-sm text-gray-500 whitespace-nowrap"><%= customer.phone %></td>
  <td class="px-3 py-4 text-sm text-gray-500 whitespace-nowrap"><%= customer.created_at.to_time.strftime('%e %b %Y, %l:%M %p ') %></td>
  <td class="relative py-4 pl-3 pr-4 text-sm font-medium text-right whitespace-nowrap sm:pr-0">
    <%= link_to edit_customer_path(customer), class: "text-indigo-600 hover:text-indigo-900" do %>
      Edit<span class="sr-only">, <%= customer.name %></span></a>
  <% end %>
</td>
</tr>